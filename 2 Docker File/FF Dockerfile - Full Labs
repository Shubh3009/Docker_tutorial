### Now, let's create the Dockerfile

######### Dockerfile #########
# Please remember that all WORKDIR and destination paths in COPY and ADD are referring to the Image and container file systems; not the docker host

# Use a small base image
FROM alpine

#Download the unzip tool, we will need to unzip a .zip file below
RUN apk add --no-cache unzip

# Set working directory
WORKDIR /app

# Copy a simple file using COPY
# Assumes hello.txt is in the build context (same folder or subdir)
COPY test.txt ./test-copy.txt

# Add a tar archive — this will auto-extract into /app/extracted-files
# Assumes files.tar.gz is in the build context - 
# The Auto extract compressed files feature of the ADD command does not support .zip compressed files.

ADD archive.tar.gz ./extracted-files/


# Create a remote directory under the /app directory. ADD when used with a URL does not create the destination directory if it does not exist
RUN mkdir -p /app/remote

# Add a remote zip app.zip file from a URL 
# This downloads the file and saves it as app.zip under the remote directory
# Uncomment the line below only if you're okay downloading from the web
ADD https://dolfined-rds-lab-aug2023.s3.us-east-1.amazonaws.com/app.zip ./remote/app.zip

#Unzip the app.zip file (this would not be required if the file was .tar, .tar.gz, tar.bz2, tar.xz)
RUN unzip ./remote/app.zip -d ./remote && rm ./remote/app.zip

# Default command
CMD ["ls", "-l", "/app"]
