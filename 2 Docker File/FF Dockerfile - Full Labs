################################## EXPOSE #####################################
###############################################################################


# Create the below Dockerfile that will expose port 80 of an Nginx base image
FROM nginx
EXPOSE 80 


# Lets build the image
$ docker build -t imageport .


# Lets run a container without port mapping to test the effect of the EXPOSE instruction in the dockerfile


$ docker run  --name cont1  imageport

# Try to connect to the container on port 80 from the host using 
$ curl http://<host private IPv4 address>:80
# This will not work, which dictates that in manual docker build images the EXPOSE is informational only.


# Now, to prove this further, lets run a container and create port mapping 3000 on the host to 80 on the containers

$ docker run -it -d -p 3000:80  port 

# Open a new browser tab, and try to access the public IPv4 address of the EC2 docker host using port 3000 

http://<EC2 docker host public IPv4>:3000 

# This should work now. It proves that EXPOSE was informational only in the Dockerfile


