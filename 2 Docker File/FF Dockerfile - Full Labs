###############################################################################
############################# ENTRYPOINT vs. CMD ##############################
###############################################################################

# the Dockerfile 
FROM ubuntu
CMD ["sleep","8"]

$ docker build -t imageent1 .
$ docker run imageent1 
# the container will sleep for 8 seconds then exits


# What if we need to override the CMD command Sleep at run time? Lets say we decide to use the command ls (to list) at the container startup time instead of sleep

$ docker run imageent1 ls 
# In this case, as you can see the "ls" command got executed and not the sleep command.
# hence, it is easy to override the CMD in the Dockerfile at runtime



# We can achieve the same we did with CMD Sleep example above using ENTRYPOINT

# the Dockerfile 
FROM ubuntu
ENTRYPOINT["sleep", "10"]

# Lets create the image and create a container and see what happens
$ docker build -t imageent2 .

$ docker run imageent2
# the container will sleep for 10 seconds then exits



# What if we need to decide the number of seconds it should sleep as we create the container, and we do not want it to be a static value into the Dockerfile? this is where ENTRYPOINT can help

# the Dockerfile 
FROM ubuntu
ENTRYPOINT["sleep"]   # without the number of seconds parameter value for sleep

# Lets create the image and create a container and pass the 15 seconds value while we create the container 
$ docker build -t imageent3 .

$ docker run imageent3 15

# The container will pass the 15 as an argument value to the sleep function and it will execute as "sleep 15" then it exits


# But then, what if we forget to add the number of seconds at the end of the docker run command?

$ docker run imageent3 
# You will get an error since Entrypoint has no parameter value for the sleep command

--------------------

# This is where combining both ENTRYPOINT for the command to be executed when the container starts and CMD to pass the default value argument to the ENTRYPOINT command.


# the Dockerfile 
FROM ubuntu
ENTRYPOINT["sleep"]
CMD ["5"]      # default seconds for the sleep command if no value is entered while creating the container

# Lets create the image, create a container, and pass the 15 seconds value while we create the container 
$ docker build -t imageent4 .
$ docker run imageent4 15
# The container will pass the 15 as an argument value to the sleep function, it will execute as "sleep 15" then the container exits

# What if we forget to add the number of seconds at the end of the docker run command?

$ docker run imageent4
# This will use the CMD default value of 5 seconds and the sleep command will execute as "sleep 5" then the container exits.


# The question now is, can we overried the ENTRYPOINT command at container runtime?
# Yes, we can do this using the "docker run" command option --entrypoint

$ docker run --entrypoint ls imageent4
# You would see that what is executed in this case is the ls command and not the sleep


--------------------
# What if the ENTRYPOINT and CMD have different commands

# the Dockerfile 
FROM ubuntu
ENTRYPOINT["sleep"]
CMD ["echo", "I am challenging ENTRYPOINT"]     

# Lets create the image, create a container, and pass the 15 seconds value while we create the container 
$ docker build -t imageent5 .
$ docker run imageent5
# You should get an error as we did not pass an argument to ENTRYPOINT at runtime and there is no default value from the CMD command

# What if we pass the argument value to ENTRYPOINT at runtime
$ docker run imageent5 8
# This should work and bypass the CMD completely. The container will sleep for 8 seconds and then exits because of the ENTRYPOINT command

