#############################    WORKDIR         ##############################
###############################################################################

# Lets demonstrate the use of WORKDIR instruction in Dockerfiles

# Dockerfile
FROM ubuntu
# Create a directly "docker" if it does not exist
WORKDIR /app
# this is effectively like cd /app
RUN echo "Welcome to the Docker Course /app" > app.txt
# create a subdirectory /code inside the /docker directory
WORKDIR /app/code
# this is effectively like cd /code
RUN echo "Welcome to the Docker Course /app/code" > container.txt
# Please note that the WORKDIR is like a cd command, anything after that WORKDIR statement applies to that directory. 

# Build the image 
$ docker build -t imageworkdir .

# Create a container from the image and start it with the command pwd in interactive mode
$ docker run -it imageworkdir pwd 

OUTPUT: /app/code
# This is because we had two "cd" commands, cd /app and cd /code which changes the default working directory inside the container as it starts.

# Lets confirm this. Use the "ls" command in the /app/code/, you will find the container.txt file.
# Type cd .. to move one step up in the filesystem. 
$ cd ..
# You will now be in the /app directory

$ pwd
# /app

# Use "ls" again to confirm that the docker.txt file exists in this directory
$ ls
# You should find the docker.txt file included



